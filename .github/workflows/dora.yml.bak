name: DORA Metrics Pipeline

on:
  push:
    branches: [main]
    paths:
      - "assignment-48-devsecops-vuln-mgmt/**"

  pull_request:
    branches: [main]
    paths:
      - "assignment-48-devsecops-vuln-mgmt/**"
jobs:
  build-deploy:
    runs-on: ubuntu-latest

    steps:
      # -----------------------------
      # Checkout Code
      # -----------------------------
      - name: Checkout Code
        uses: actions/checkout@v4

      # -----------------------------
      # Build & Deploy Simulation
      # -----------------------------
      - name: Simulate Build
        run: echo "Building app..."

      - name: Simulate Deployment
        run: |
          echo "Deploying app..."
          date > deployment.txt

      # -----------------------------
      # Security Scan + Gate
      # -----------------------------
      - name: Simulate Security Scan
        run: |
          echo "Running security scan..."
          echo '{"severity":"LOW"}' > results.json

      - name: Fail on Critical Issues
        run: |
          if grep -q CRITICAL results.json; then
            echo "❌ Critical vulnerabilities found!"
            exit 1
          else
            echo "✅ No critical issues"
          fi

      # -----------------------------
      # DORA Metrics Tracking
      # -----------------------------
      - name: Track Deployment Frequency
        run: |
          echo "Deployment recorded at $(date)" >> dora_metrics.log
          echo "Commit: $GITHUB_SHA" >> dora_metrics.log
          echo "Author: $GITHUB_ACTOR" >> dora_metrics.log

      # -----------------------------
      # Emit DORA Events (Four Keys)
      # -----------------------------
      - name: Emit Deployment Event
        run: |
          bash assignment-39-dora-metrics/scripts/emit_dora.sh deployment success

      - name: Emit Recovery Event
        if: success()
        run: |
          bash assignment-39-dora-metrics/scripts/emit_dora.sh recovery success

      - name: Emit Incident Event (on failure)
        if: failure()
        run: |
          bash assignment-39-dora-metrics/scripts/emit_dora.sh incident failure

      # -----------------------------
      # Upload Artifacts
      # -----------------------------
      - name: Upload DORA Metrics Artifact
        uses: actions/upload-artifact@v4
        with:
          name: dora-metrics
          path: dora_metrics.log

      - name: Upload DORA Event
        uses: actions/upload-artifact@v4
        with:
          name: dora-event
          path: dora_event.json

      # -----------------------------
      # Send Event to Datadog
      # -----------------------------
      - name: Send DORA Event to Datadog
        if: always()
        env:
          DD_API_KEY: ${{ secrets.DD_API_KEY }}
        run: |
          if [-f dora_event.json]; then
            curl -X POST "https://api.datadoghq.com/api/v1/events" \
              -H "Content-type: application/json" \
              -H "DD-API-KEY: $DD_API_KEY" \
              -d @dora_event.json || true
          else
            echo "No event file found"
          fi
